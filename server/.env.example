# =============================================
# AI Face Recognition Attendance System
# Pre-configured for XAMPP MySQL
# =============================================

PORT=5000
NODE_ENV=development

# XAMPP MySQL Settings
# XAMPP default: root user, NO password, port 3306
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=face_attendance_db

# JWT Secret — change this to any long random string
JWT_SECRET=faceAttendSystem2024SecretKeyXAMPP_ChangeThis
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# CORS
CLIENT_URL=http://localhost:3000
